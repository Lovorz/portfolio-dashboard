# Note: To use the Gmail REST API, place your Google Cloud Desktop Client secret JSON file (named client_secret_*.json) in this directory.

# Dime PDF Decryption Password (usually Thai ID card number or Date of Birth in DDMMYYYY format)
DIME_PDF_PASSWORD=your_id_card_number

# Mistral AI API Key (from console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key
